{
  "name": "nepali-bs-calendar-react",
  "version": "0.1.0",
  "description": "A lightweight React Nepali Bikram Sambat calendar/date picker component.",
  "license": "MIT",
  "author": "Sarun Bhatta",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/index.css",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/index.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --external react-dom",
    "prepublishOnly": "npm run build",
    "pack:local": "npm pack"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "react",
    "nepali-calendar",
    "bikram-sambat",
    "bs-date",
    "datepicker",
    "calendar"
  ]
}
